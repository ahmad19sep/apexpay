<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Top Up"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Amount"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCustomAmount"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Quick Amount Chips -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3">

                <TextView
                    android:id="@+id/chipAmt50"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="$50"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/chipAmt100"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="$100"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/chipAmt200"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="$200"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/chipAmt500"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="$500"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/chipAmt1000"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="$1000"
                    android:textColor="@color/text_secondary" />

            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Payment Source"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgSources"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <RadioButton
                    android:id="@+id/rbBank1"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_input_field"
                    android:checked="true"
                    android:paddingHorizontal="16dp"
                    android:text="HBL Bank ••3421"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/rbBank2"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:text="Meezan Bank ••7890"
                    android:textColor="@color/text_primary" />

            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnTopUp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primary"
        android:text="Top Up Now"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>
