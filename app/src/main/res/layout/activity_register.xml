<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <TextView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="⬡"
            android:textSize="50sp"
            android:textColor="#6366F1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="APEX PAY"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Your financial ecosystem"
            android:textSize="13sp"
            android:textColor="#8892B0" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#131523"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Profile photo row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="👤"
                        android:textSize="18sp"
                        android:background="@drawable/bg_avatar_circle" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile Photo"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to upload a photo"
                            android:textSize="12sp"
                            android:textColor="#8892B0" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="58dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="Choose"
                        android:textSize="11sp"
                        android:textColor="#6366F1"
                        android:background="#22253A" />

                </LinearLayout>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Full name"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8892B0"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Email address"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8892B0"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="6dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8892B0"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="👁"
                        android:textSize="18sp"
                        android:alpha="0.5"
                        android:paddingEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Password strength indicator -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginBottom="12dp"
                    android:background="#22253A">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="start"
                        android:scaleX="0.6"
                        android:transformPivotX="0dp"
                        android:background="#00C896" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Confirm password"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8892B0"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btnToggleConfirmPassword"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="👁"
                        android:textSize="18sp"
                        android:alpha="0.5"
                        android:paddingEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6366F1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="I agree to the Terms of Service &amp; Privacy Policy"
                        android:textColor="#8892B0"
                        android:textSize="12sp" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="#6366F1"
                    android:text="⬡  Create Secure Account"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="#6366F1"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvGoToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="Already have an account?  Sign In"
            android:textColor="#8892B0"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
