<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#131523"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#44FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp" />

    <!-- Asset header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvTradeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_asset_icon"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTradeAssetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvTradePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#8892B0"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTradeChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Buy / Sell toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/btnBuyTab"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="BUY"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_buy_btn"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnSellTab"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SELL"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#8892B0"
            android:background="@drawable/bg_tab_inactive"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Amount input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/btnAmountMinus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="−"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_tab_inactive"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:hint="0.00"
            android:textColorHint="#44FFFFFF"
            android:background="@drawable/bg_order_input"
            android:paddingHorizontal="16dp" />

        <TextView
            android:id="@+id/btnAmountPlus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="+"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_tab_inactive"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Quick pct buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="20dp">

        <TextView android:id="@+id/btn25pct"
            android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:gravity="center"
            android:text="25%" android:textSize="12sp" android:textColor="#8892B0"
            android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/btn50pct"
            android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:gravity="center"
            android:text="50%" android:textSize="12sp" android:textColor="#8892B0"
            android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/btn75pct"
            android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:gravity="center"
            android:text="75%" android:textSize="12sp" android:textColor="#8892B0"
            android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/btnMax"
            android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:gravity="center"
            android:text="Max" android:textSize="12sp" android:textColor="#6366F1"
            android:background="@drawable/bg_tab_inactive"/>

    </LinearLayout>

    <!-- Order details card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#1A1C2E"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Details"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <!-- Fractional shares -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Shares / Units" android:textSize="13sp" android:textColor="#8892B0"/>
                <TextView android:id="@+id/tvFractionalShares" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0000" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Order value -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Order Value" android:textSize="13sp" android:textColor="#8892B0"/>
                <TextView android:id="@+id/tvOrderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0.00" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Network fee -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Network Fee (1%)" android:textSize="13sp" android:textColor="#8892B0"/>
                <TextView android:id="@+id/tvNetworkFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0.00" android:textSize="13sp" android:textColor="#FF5252"/>
            </LinearLayout>

            <!-- Spread -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Spread (0.65%)" android:textSize="13sp" android:textColor="#8892B0"/>
                <TextView android:id="@+id/tvSpread" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0.00" android:textSize="13sp" android:textColor="#FF5252"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22253A" android:layout_marginBottom="12dp"/>

            <!-- Total -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                <TextView android:id="@+id/tvTotalDeducted" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0.00" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Available balance -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Available Balance" android:textSize="13sp" android:textColor="#8892B0"/>
                <TextView android:id="@+id/tvAvailableBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0.00" android:textSize="13sp" android:textColor="#00C896"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Confirm button -->
    <Button
        android:id="@+id/btnConfirmTrade"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:text="Confirm Trade"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_confirm_btn"
        android:stateListAnimator="@null" />

    <!-- Disclaimer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Simulated only. No real assets are purchased. Apex Pay uses mock execution for educational purposes."
        android:textSize="10sp"
        android:textColor="#44FFFFFF"
        android:paddingHorizontal="20dp" />

</LinearLayout>
