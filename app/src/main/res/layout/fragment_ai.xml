<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brokerage_bg"
    android:orientation="vertical"
    android:fitsSystemWindows="true">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Risk Analyst"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by Groq"
                android:textSize="12sp"
                android:textColor="#8892B0" />

        </LinearLayout>


        <ImageButton
            android:id="@+id/btnScanToInvest"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_scan"
            android:background="#1A1C2E"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            app:tint="#6366F1"
            android:contentDescription="Scan to Invest" />


        <TextView
            android:id="@+id/btnClearChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear"
            android:textSize="12sp"
            android:textColor="#8892B0"
            android:background="#1A1C2E"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp" />

    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E2035" />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />


    <LinearLayout
        android:id="@+id/llTyping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <ProgressBar
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminateTint="#6366F1"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyst is thinking…"
            android:textSize="13sp"
            android:textColor="#8892B0" />

    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#131523"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <EditText
            android:id="@+id/etAiInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="Ask about any asset or risk…"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="12dp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnAiSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_send"
            android:background="#6366F1"
            android:padding="12dp"
            app:tint="#FFFFFF"
            android:contentDescription="Send" />

    </LinearLayout>

</LinearLayout>
